generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Question {
  id               Int       @id @default(autoincrement())
  url              String    @unique(map: "url") @db.VarChar(255)
  title            String?   @db.Text
  body             String?   @db.Text
  bodyLength Int?
  notfoundAt       DateTime? @db.DateTime(0)
  postId           Int?
  publishedAt      DateTime? @db.DateTime(0)
  miiboStatus      Int?
  miiboCommentedAt DateTime? @db.DateTime(0)
  title_summary_llama3_1_8b String? @db.Text
  body_summary_llama3_1_8b  String? @db.Text
  title_summary_phi4_14b String? @db.Text
  body_summary_phi4_14b  String? @db.Text
  title_summary_qwen3_8b String? @db.Text
  body_summary_qwen3_8b  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Questions")
}
